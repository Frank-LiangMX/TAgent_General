{
  "name": "tagent",
  "version": "0.0.0-dev",
  "private": true,
  "description": "TAgent — game TA domain + general agent (Electron desktop app)",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "jotai": "^2.17.1"
  },
  "scripts": {
    "dev": "bun run --filter='@tagent/electron' dev",
    "dev-start": "bun run dev",
    "dev-stop": "bun run --filter='@tagent/electron' dev-stop",
    "electron:dev": "bun run --filter='@tagent/electron' dev",
    "electron:build": "bun run --filter='@tagent/electron' build",
    "build": "bun run --filter='*' build",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.9.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  }
}
